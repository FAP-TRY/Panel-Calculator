# Installer build artifacts (generated by build.bat, do not commit)
Installer/app-raw/
Installer/app-obf/
Installer/app-final/
Installer/Output/
Installer/build_out.txt
Installer/build_err.txt

# Single-file release build staging (generated by Tools/build-release-singlefile.ps1)
release-build-staging/

# Binary data/price-list files
*.xlsx
*.xls
*.pdf

# License signing key (Item #5 — Ed25519 private key, NEVER commit!)
# The generator writes it as license-private.key in whatever directory the
# admin runs the tool from. Belt-and-braces: ignore any *.key file too.
license-private.key
**/license-private.key
*.key

# Developer license bypass flag (Item #5 — local-only marker file that
# disables the license gate in Release builds running on a dev machine).
Tools/dev-bypass.flag
dev-bypass.flag
